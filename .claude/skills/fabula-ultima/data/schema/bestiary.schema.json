{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fu/bestiary.schema.json",
  "title": "Fabula Ultima — bestiary stat blocks (one file per species)",
  "type": "object",
  "required": ["id", "source", "species", "entries"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "source": { "type": "string", "enum": ["core", "high", "natural", "techno"] },
    "species": { "type": "string", "enum": ["beast", "construct", "demon", "elemental", "humanoid", "monster", "plant", "undead"] },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "name", "level", "species", "attributes", "hp", "mp", "initiative", "defense", "magic_defense", "attacks"],
        "additionalProperties": true,
        "properties": {
          "key": { "type": "string" },
          "name": { "type": "string" },
          "level": { "type": "integer" },
          "species": { "type": "string", "enum": ["beast", "construct", "demon", "elemental", "humanoid", "monster", "plant", "undead"] },
          "rank": { "type": "string", "description": "soldier / elite / champion(N) if noted" },
          "attributes": {
            "type": "object",
            "required": ["DEX", "INS", "MIG", "WLP"],
            "additionalProperties": false,
            "properties": {
              "DEX": { "type": "integer", "enum": [6, 8, 10, 12] },
              "INS": { "type": "integer", "enum": [6, 8, 10, 12] },
              "MIG": { "type": "integer", "enum": [6, 8, 10, 12] },
              "WLP": { "type": "integer", "enum": [6, 8, 10, 12] }
            }
          },
          "hp": { "type": "integer" },
          "mp": { "type": "integer" },
          "crisis": { "type": "integer" },
          "initiative": { "type": "integer" },
          "defense": { "type": "integer" },
          "magic_defense": { "type": "integer" },
          "affinities": {
            "type": "object",
            "description": "map of damage type -> affinity",
            "additionalProperties": { "type": "string", "enum": ["vulnerable", "resistant", "immune", "absorb"] }
          },
          "attacks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "text"],
              "additionalProperties": true,
              "properties": {
                "name": { "type": "string" },
                "accuracy": { "type": "string", "description": "e.g. '[DEX+MIG]+1' verbatim" },
                "damage": { "type": "string", "description": "e.g. '[HR+8] physical' verbatim" },
                "range": { "type": "string", "enum": ["melee", "ranged"] },
                "text": { "type": "string" }
              }
            }
          },
          "skills": {
            "type": "array",
            "items": { "type": "object", "required": ["name", "text"], "properties": { "name": { "type": "string" }, "text": { "type": "string" } } }
          },
          "traits": { "type": "array", "items": { "type": "string" } },
          "equipment": { "type": "array", "items": { "type": "string" } },
          "text": { "type": "string" }
        }
      }
    }
  }
}
